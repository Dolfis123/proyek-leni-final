# .env (di root folder frontend Anda)

# Base URL untuk API Backend Anda
# Pastikan ini mengarah ke ROOT URL backend Anda (misal: http://localhost:5000)
# BUKAN http://localhost:5000/api, karena Socket.IO terhubung ke root server
VITE_API_BASE_URL=http://localhost:5000/api

# Jika Anda memiliki URL frontend yang berbeda untuk deployment, Anda bisa tambahkan di sini
VITE_FRONTEND_URL=https://www.skydance.life