# .env (di root folder frontend Anda)

# Base URL untuk API Backend Anda
# Ini harus menunjuk ke domain publik yang di-proxy oleh Nginx
VITE_API_BASE_URL=https://pengadilannegerimanokwari.pro/api
# VITE_API_BASE_URL=http://localhost:5000/api

# URL untuk koneksi Socket.IO (biasanya sama dengan root domain frontend)
# Ini harus menunjuk ke domain publik yang di-proxy oleh Nginx
VITE_SOCKET_URL=https://pengadilannegerimanokwari.pro/api